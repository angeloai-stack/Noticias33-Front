# ---------- Sitio público ----------
# URL pública del sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API REST de WordPress (lectura de noticias)
NEXT_PUBLIC_API_URL=https://noticias33.com/wp-json/wp/v2

# ---------- Sistema de publicación (solo servidor) ----------
# URL base de WordPress
WP_URL=https://noticias33.com

# Usuario de WordPress con permisos de publicación
WP_USER=

# Application Password de WordPress (wp-admin -> Usuarios -> Perfil -> Contraseñas de aplicación)
WP_APP_PASSWORD=

# ---------- Supabase: logs de publicación y suscriptores (solo servidor) ----------
# URL del proyecto Supabase (https://xxxx.supabase.co)
SUPABASE_URL=

# Service Role Key de Supabase (secreta, nunca exponer en el frontend)
SUPABASE_SERVICE_KEY=

# ---------- Claves de acceso ----------
# Clave para redactores (/publicar)
NEXT_PUBLIC_ACCESS_CODE=

# Clave para administradores (/admin)
NEXT_PUBLIC_ADMIN_CODE=
